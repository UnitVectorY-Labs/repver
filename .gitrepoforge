name: repver
default_branch: main
config:
  description: "Automate batch replacement of simple strings, like version numbers, across multiple files and handle all Git steps with one command."
  license: MIT
  language: go
  release: release-go
  justfile: true
  codecov:
    enabled: true
  docs:
    enabled: true
    domain: repver.unitvectorylabs.com
